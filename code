<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Podcast Player</title>

<script src="https://telegram.org/js/telegram-web-app.js"></script>

<style>
body{
    font-family: Arial;
    background:#0f0f0f;
    color:white;
    text-align:center;
    padding-top:60px;
}

.player{
    margin-top:30px;
}

audio{
    width:80%;
}
</style>
</head>

<body>

<h1>🎙 My Podcast</h1>
<p>Listen directly in Telegram</p>

<div class="player">
<audio controls>
<source src="podcast.mp3" type="audio/mpeg">
</audio>
</div>

</body>
</html>
